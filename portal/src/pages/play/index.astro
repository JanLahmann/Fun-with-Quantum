---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import qoffeePhoto from '../../assets/qoffee-event.jpg';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
const qoffee = (await getCollection('projects')).find((p) => p.id === 'qoffee-maker');
---

<Base
  title="Play — quantum games | Fun with Quantum"
  description="Quantum games you play in the browser: beat a quantum computer at coin flipping, win an impossible team game with entanglement, and order your coffee with a quantum circuit."
>
  <section class="section">
    <div class="wrap">
      <div class="kicker">Play</div>
      <h2>Games where quantum mechanics is the trick</h2>
      <p class="lead">
        Nothing to install, no account — every game here runs in your browser or, in one case,
        brews your coffee.
      </p>

      {qoffee && (
        <a class="feature card" href={qoffee.data.url} target="_blank" rel="noopener">
          <Image src={qoffeePhoto} alt="The Qoffee-Maker at a conference — a coffee machine wired to a quantum circuit composer" widths={[420, 800]} sizes="(max-width: 820px) 90vw, 420px" />
          <div>
            <h3>{qoffee.data.icon} {qoffee.data.title} ↗</h3>
            <p class="feature-tag">{qoffee.data.tagline}</p>
            <p class="feature-text">
              Build a quantum circuit whose measurement outcome decides which drink the machine
              brews. Put the qubits in superposition and let physics choose — a conference
              favorite, and the most caffeinated way ever devised to learn what a measurement is.
            </p>
            <span class="meta">qoffee-maker.org ↗</span>
          </div>
        </a>
      )}

      <h2 class="games-title">The notebook games</h2>
      <p class="lead">
        Each game is an interactive notebook — one click, a short cold start, no account.
        Play first, then open the curtain and see the circuit.
      </p>
      <div class="grid cols-2">
        {games.map((g) => (
          <a class="card" href={`/play/${g.id}/`}>
            <span class="icon">{g.data.icon}</span>
            <h3>{g.data.title}</h3>
            <p>{g.data.tagline}</p>
            <span class="meta">{g.data.concept} · {g.data.duration}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .feature {
    display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 28px; align-items: center;
    margin-bottom: 12px;
  }
  @media (max-width: 820px) { .feature { grid-template-columns: 1fr; } }
  .feature img { border-radius: 12px; width: 100%; height: auto; }
  .feature h3 { font-size: 1.35rem; margin-bottom: 6px; }
  .feature-tag { color: var(--muted); font-size: 0.93rem; margin-bottom: 10px; }
  .feature-text { font-size: 0.93rem; color: var(--muted); margin-bottom: 12px; }
  .games-title { margin-top: 48px; }
</style>
