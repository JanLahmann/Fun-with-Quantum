---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectRow from '../components/ProjectRow.astro';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.door === 'learn')
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Learn — quantum computing hands-on | Fun with Quantum"
  description="Learn quantum computing hands-on, starting with IBM Quantum Learning's free interactive courses. More learning resources from the Fun with Quantum family are coming soon."
>
  <section class="section">
    <div class="wrap">
      <div class="kicker">Learn</div>
      <h2>From first qubit to your own experiments</h2>
      <p class="lead">
        The best place to start today is IBM Quantum Learning — free, interactive, and made by the
        people who build the machines.
      </p>

      {projects.map((p) => <ProjectRow project={p} />)}

      <div class="soon card">
        <span class="badge soon">coming soon</span>
        More from the family is on the way: interactive tutorials that run entirely in your
        browser, ready-made workshop agendas, and always-current Qiskit coding environments.
      </div>
    </div>
  </section>
</Base>

<style>
  .soon { font-size: 0.93rem; color: var(--muted); }
  .soon .badge { margin-bottom: 10px; align-self: flex-start; }
</style>
