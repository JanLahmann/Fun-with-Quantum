---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import heroPhoto from '../assets/RasQberry2model.png';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
const featured = games.find((g) => g.data.featured) ?? games[0];

const doors = [
  {
    href: '/play/',
    icon: '🎲',
    title: 'Play',
    text: 'Beat a quantum computer at coin flipping, drag gates in the composer, order coffee with a circuit.',
    meta: `${games.length} games · QAMPoser · Qoffee-Maker`,
  },
  {
    href: '/build/',
    icon: '🛠️',
    title: 'Build',
    text: '3D-print or LEGO-build your own model of an IBM Quantum computer.',
    meta: 'RasQberry · Quantego · Qutie',
  },
  {
    href: '/learn/',
    icon: '📚',
    title: 'Learn',
    text: 'Interactive tutorials, guided workshops, and ready-made coding environments.',
    meta: 'doQumentation · Workshops · QuBins',
  },
];

const tryItems = [
  {
    href: 'https://qamposer.org',
    icon: '🎛️',
    title: 'Compose a circuit',
    text: 'Drag gates onto the wires, run it live in your browser — the composer behind the Qoffee-Maker.',
    meta: 'qamposer.org ↗',
  },
  {
    href: 'https://qubins.org',
    icon: '📦',
    title: 'Launch any notebook',
    text: 'Paste a repo or notebook URL, get a one-click Binder environment on always-current Qiskit.',
    meta: 'qubins.org ↗',
  },
  {
    href: 'https://quantego.org',
    icon: '🧱',
    title: 'Spin the models',
    text: 'All three Quantego LEGO models in interactive 3D, at true relative scale.',
    meta: 'quantego.org ↗',
  },
];
---

<Base
  title="Fun with Quantum — play, print & run quantum computing"
  description="Quantum games, 3D-printed and LEGO quantum computer models, interactive courses, and ready-made coding environments. Open source, nothing to install."
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <h1>Quantum computing you can play, print&nbsp;&amp;&nbsp;run — nothing to install.</h1>
        <p>
          Games, LEGO and 3D-printed quantum computers, interactive courses, and ready-made coding
          environments. Open source, workshop-tested, built by the RasQberry community.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={featured.data.binderUrl}>▶ Play the {featured.data.title}</a>
          <a class="btn ghost" href="#doors">Explore the family</a>
        </div>
        <div class="hero-note">launches in your browser via Binder · ~30 s cold start · no account needed</div>
      </div>
      <figure class="hero-photo">
        <Image src={heroPhoto} alt="RasQberry Two — a 3D-printed model of IBM Quantum System Two with glowing LEDs" widths={[480, 760]} sizes="(max-width: 820px) 90vw, 480px" />
        <figcaption>RasQberry Two — 3D-printed at home, quantum inside</figcaption>
      </figure>
    </div>
  </section>

  <section class="section" id="doors">
    <div class="wrap">
      <div class="grid cols-3">
        {doors.map((d) => (
          <a class="card door" href={d.href}>
            <span class="icon">{d.icon}</span>
            <h3>{d.title}</h3>
            <p>{d.text}</p>
            <span class="meta">{d.meta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="kicker">Try it right here</div>
      <h2>No install, no account</h2>
      <p class="lead">Three live pieces of the family, one click away.</p>
      <div class="grid cols-3">
        {tryItems.map((t) => (
          <a class="card" href={t.href}>
            <span class="icon">{t.icon}</span>
            <h3>{t.title}</h3>
            <p>{t.text}</p>
            <span class="meta">{t.meta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="tagline-strip">
    <b>GOD DOES PLAY DICE.</b> COME PLAY, BUILD, LEARN.
  </div>

  <div class="trust wrap">
    <span>100% open source</span>
    <span>no accounts, no cookies</span>
    <span>Qiskit ecosystem</span>
    <span>workshop-ready</span>
    <span>from the makers of RasQberry</span>
  </div>
</Base>

<style>
  .hero { padding: 56px 0 24px; }
  .hero-grid {
    display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 48px; align-items: center;
  }
  @media (max-width: 820px) { .hero-grid { grid-template-columns: 1fr; } }
  .hero h1 { font-size: 2.5rem; margin-bottom: 18px; }
  @media (max-width: 820px) { .hero h1 { font-size: 1.9rem; } }
  .hero-copy p { color: var(--muted); max-width: 520px; margin-bottom: 26px; }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-note {
    margin-top: 14px; font-family: var(--mono); font-size: 0.72rem;
    letter-spacing: 0.04em; color: var(--muted);
  }
  .hero-photo img {
    border-radius: 16px; box-shadow: var(--shadow); width: 100%; height: auto;
  }
  .hero-photo figcaption {
    margin-top: 10px; font-size: 0.8rem; color: var(--muted); text-align: center;
  }
  .card.door h3 { font-size: 1.35rem; }
</style>
