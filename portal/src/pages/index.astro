---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import heroPhoto from '../assets/RasQberry2model.png';
import qoffeeMug from '../assets/qoffee-mug.png';
import quantegoPhoto from '../assets/quantego-two-photo.jpg';
import ibmLearning from '../assets/ibm-quantum-learning.png';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
const featured = games.find((g) => g.data.featured) ?? games[0];

const doors = [
  {
    href: '/play/',
    img: qoffeeMug,
    imgAlt: 'The Qoffee-Maker mug with a quantum circuit printed on it',
    fit: 'contain',
    title: 'Play',
    text: 'Beat a quantum computer at coin flipping, win an impossible team game with entanglement, order coffee with a circuit.',
    links: [
      { label: `${games.length} games`, href: '/play/' },
      { label: 'Qoffee-Maker', href: 'https://qoffee-maker.org' },
    ],
  },
  {
    href: '/build/',
    img: quantegoPhoto,
    imgAlt: 'Quantego — a LEGO model of an IBM Quantum computer, mid-build',
    fit: 'cover',
    title: 'Build',
    text: '3D-print or LEGO-build your own model of an IBM Quantum computer.',
    links: [
      { label: 'RasQberry', href: 'https://rasqberry.org' },
      { label: 'Quantego', href: 'https://quantego.org' },
      { label: 'Qutie', href: 'https://qutie.org' },
    ],
  },
  {
    href: '/learn/',
    img: ibmLearning,
    imgAlt: 'The IBM Quantum Learning platform: “Learn quantum computing” with a library of courses',
    fit: 'left',
    title: 'Learn',
    text: 'Start with IBM Quantum Learning — free, interactive, and made by the people who build the machines. Keep coding in ready-made environments.',
    links: [
      { label: 'IBM Quantum Learning', href: 'https://learning.quantum.ibm.com' },
      { label: 'QuBins', href: 'https://qubins.org' },
    ],
  },
];
---

<Base
  title="Fun with Quantum — play, print & run quantum computing"
  description="Quantum games, 3D-printed and LEGO quantum computer models, and hands-on ways to learn. Open source, nothing to install."
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <h1>Quantum computing you can <span class="hl-c">play</span>, <span class="hl-m">print&nbsp;&amp;&nbsp;run</span> — nothing to install.</h1>
        <p>
          Quantum games, LEGO and 3D-printed quantum computers, and hands-on ways to learn.
          Open source, workshop-tested, built by the RasQberry community.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={featured.data.binderUrl} target="_blank" rel="noopener">▶ Play the {featured.data.title}</a>
          <a class="btn ghost" href="/#doors">Explore the family</a>
        </div>
        <div class="hero-note">launches in your browser via Binder · ~30 s cold start · no account needed</div>
      </div>
      <figure class="hero-photo">
        <Image src={heroPhoto} alt="RasQberry Two — a 3D-printed model of IBM Quantum System Two with glowing LEDs" widths={[480, 760]} sizes="(max-width: 820px) 90vw, 520px" />
        <figcaption>RasQberry Two — 3D-printed at home, quantum inside</figcaption>
      </figure>
    </div>
  </section>

  <section class="section" id="doors">
    <div class="wrap">
      <div class="grid cols-3">
        {doors.map((d) => (
          <div class="card door">
            <div class={`thumb ${d.fit}`}>
              <Image src={d.img} alt={d.imgAlt} widths={[480, 760]} sizes="(max-width: 820px) 90vw, 340px" />
            </div>
            <h3><a href={d.href}>{d.title} <span class="arrow">→</span></a></h3>
            <p>{d.text}</p>
            <span class="meta">
              {d.links.map((l, i) => (
                <>
                  {i > 0 && ' · '}
                  <a href={l.href} {...(l.href.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}>{l.label}</a>
                </>
              ))}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="try">
    <div class="wrap">
      <div class="kicker">Try it right here — no install, no account</div>
      <h2 class="sr-only">Try it right here</h2>
      <div class="grid cols-3 try-grid">
        <div class="card">
          <h3>Play Quantum Runner</h3>
          <p>Steer the runner with quantum gates — an H gate puts you in both lanes at once.</p>
          <video
            class="runner-video"
            src="/quantum-runner.mp4"
            autoplay
            muted
            loop
            playsinline
            aria-label="Quantum Runner gameplay: building a circuit steers the runner across lanes"
          ></video>
          <span class="meta">
            built on QAMPoser — playable embed coming shortly ·{' '}<a href="https://qamposer.org" target="_blank" rel="noopener">qamposer.org ↗</a>
          </span>
        </div>

        <div class="card">
          <h3>Launch any notebook</h3>
          <p>Paste a GitHub repo or notebook URL, get a one-click Binder environment.</p>
          <form class="launch-form" id="launch-form">
            <input
              id="launch-input"
              type="text"
              placeholder="github.com/you/your-notebook"
              aria-label="GitHub repository or notebook URL"
              autocomplete="off"
              spellcheck="false"
            />
            <button class="btn primary" type="submit">Launch ▸</button>
          </form>
          <div class="launch-hint" id="launch-hint" hidden>Use a github.com repository or .ipynb link.</div>
          <span class="meta">
            powered by the{' '}<a href="https://qubins.org" target="_blank" rel="noopener">live QuBins launch generator ↗</a>
          </span>
        </div>

        <div class="card">
          <h3>Spin the models</h3>
          <p>Quantego, the LEGO model of IBM Quantum System Two — drag to spin, live in 3D.</p>
          <model-viewer
            src="https://quantego.org/assets/models/quantego-two.glb"
            poster="https://quantego.org/Quantego-Two/Quantego-Two.png"
            alt="Interactive 3D model of Quantego Two, a LEGO IBM Quantum computer"
            camera-controls
            auto-rotate
            loading="lazy"
            touch-action="pan-y"
          ></model-viewer>
          <span class="meta">
            all three models at{' '}<a href="https://quantego.org" target="_blank" rel="noopener">quantego.org ↗</a>
          </span>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <div class="wrap">
      <div class="kicker">About</div>
      <h2>One family, one idea: quantum computing is more fun hands-on</h2>
      <div class="prose">
        <p>
          <em>Fun with Quantum</em> is the front door to a family of open-source quantum outreach
          projects that grew over years of talks, workshops, and conference booths: quantum{' '}<a href="/play/">games</a>{' '}you play in the browser, quantum computer models you{' '}<a href="/build/">3D-print or build from LEGO</a>, and hands-on ways to{' '}<a href="/learn/">learn and teach</a>. Everything is open source, runs without
          accounts or installs, and is tested on real audiences — from school classes to IEEE
          conferences.
        </p>
        <p>
          The family is built by <a href="https://www.linkedin.com/in/JanLahmann" target="_blank" rel="noopener">Jan-R.
          Lahmann</a> and the RasQberry community. Contributions are welcome in every repository —
          start at <a href="https://github.com/JanLahmann" target="_blank" rel="noopener">github.com/JanLahmann</a>.
        </p>
      </div>
    </div>
  </section>

  <div class="tagline-strip">
    <b>GOD DOES PLAY DICE.</b> COME PLAY, BUILD, LEARN.
  </div>

  <div class="trust wrap">
    <span>100% open source</span>
    <span>no accounts, no cookies</span>
    <span>Qiskit ecosystem</span>
    <span>workshop-ready</span>
    <span>from the makers of RasQberry</span>
  </div>
</Base>

<script is:inline type="module" src="https://cdn.jsdelivr.net/npm/@google/model-viewer@3.5.0/dist/model-viewer.min.js"></script>

<script>
  const form = document.getElementById('launch-form') as HTMLFormElement | null;
  const input = document.getElementById('launch-input') as HTMLInputElement | null;
  const hint = document.getElementById('launch-hint');

  function buildLaunchUrl(raw: string): string | null {
    let s = raw.trim().replace(/^https?:\/\//, '').replace(/^www\./, '');
    if (!s) return null;
    let owner: string, repo: string, branch = '', path = '';
    const gh = s.match(/^github\.com\/([^/]+)\/([^/]+?)(?:\.git)?(?:\/(?:blob|tree)\/([^/]+)\/(.+?))?\/?$/);
    if (gh) {
      owner = gh[1];
      repo = gh[2];
      branch = gh[3] || '';
      path = gh[4] || '';
    } else {
      const short = s.match(/^([\w.-]+)\/([\w.-]+)\/?$/);
      if (!short) return null;
      owner = short[1];
      repo = short[2];
    }
    const q = new URLSearchParams({ image: '2.1-xl', repo: `https://github.com/${owner}/${repo}` });
    if (branch) q.set('branch', branch);
    if (path) q.set('path', path);
    return `https://qubins.org/launch/?${q.toString()}`;
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const url = buildLaunchUrl(input?.value ?? '');
    if (url) {
      hint?.setAttribute('hidden', '');
      window.open(url, '_blank', 'noopener');
    } else {
      hint?.removeAttribute('hidden');
    }
  });
</script>

<style>
  .hero { padding: 56px 0 24px; }
  .hero-grid {
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center;
  }
  @media (max-width: 820px) { .hero-grid { grid-template-columns: 1fr; } }
  .hero h1 { font-size: 2.5rem; margin-bottom: 18px; }
  @media (max-width: 820px) { .hero h1 { font-size: 1.9rem; } }
  .hero h1 .hl-c { color: var(--cyan); }
  .hero h1 .hl-m {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-copy p { color: var(--muted); max-width: 520px; margin-bottom: 26px; }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-note {
    margin-top: 14px; font-family: var(--mono); font-size: 0.72rem;
    letter-spacing: 0.04em; color: var(--muted);
  }
  .hero-photo img {
    border-radius: 16px; box-shadow: var(--shadow); width: 100%; height: auto;
  }
  .hero-photo figcaption {
    margin-top: 10px; font-size: 0.8rem; color: var(--muted); text-align: center;
  }
  .card.door h3 { font-size: 1.35rem; }

  /* --- try band --- */
  #try .kicker { margin-bottom: 22px; }
  .try-grid .card h3 { font-size: 1.12rem; }
  .runner-video {
    width: 100%; height: 175px; object-fit: cover; object-position: top;
    border: 1px solid var(--line); border-radius: 10px; background: #14151D;
  }
  .launch-form { display: flex; gap: 10px; }
  .launch-form input {
    flex: 1; min-width: 0;
    font-family: var(--mono); font-size: 0.8rem;
    padding: 10px 12px; border: 1px solid var(--line); border-radius: 9px;
    background: var(--paper); color: var(--ink);
  }
  .launch-form input:focus { outline: 2px solid var(--cyan); outline-offset: -1px; border-color: var(--cyan); }
  .launch-form .btn { padding: 9px 16px; font-size: 0.88rem; }
  .launch-hint { font-size: 0.78rem; color: var(--magenta); }
  model-viewer {
    width: 100%; height: 175px;
    border: 1px solid var(--line); border-radius: 10px;
    /* poster as background so the card isn't empty before the viewer script loads */
    background: #fff url('https://quantego.org/Quantego-Two/Quantego-Two.png') center / contain no-repeat;
    --poster-color: #fff;
  }
</style>
