---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import ProjectRow from '../components/ProjectRow.astro';
import rasqberryPhoto from '../assets/RasQberry2model.png';
import quantegoPhoto from '../assets/quantego-two-photo.jpg';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.door === 'build')
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Build — 3D-printed & LEGO quantum computers | Fun with Quantum"
  description="Build your own model of an IBM Quantum computer: 3D-print the RasQberry Two with a Raspberry Pi inside, brick-build Quantego from LEGO, or wait for the palm-sized Qutie."
>
  <section class="section">
    <div class="wrap">
      <div class="kicker">Build</div>
      <h2>Quantum computers for your desk</h2>
      <p class="lead">
        Models of real IBM Quantum systems you can make yourself — from a weekend 3D-print with a
        Raspberry Pi inside to LEGO builds for the whole family.
      </p>

      <div class="photos grid cols-3">
        <figure>
          <Image src={rasqberryPhoto} alt="RasQberry Two — a 3D-printed model of IBM Quantum System Two with glowing LEDs" widths={[420, 800]} sizes="(max-width: 820px) 90vw, 420px" />
          <figcaption>RasQberry Two — 3D-printed at home</figcaption>
        </figure>
        <figure>
          <video src="/quantego-one-animation.mp4" autoplay loop muted playsinline aria-label="Quantego One assembling itself brick by brick, animated"></video>
          <figcaption>Quantego One, brick by brick</figcaption>
        </figure>
        <figure>
          <Image src={quantegoPhoto} alt="Quantego Two — a LEGO model of an IBM Quantum computer" widths={[420, 800]} sizes="(max-width: 820px) 90vw, 420px" />
          <figcaption>Quantego Two, built from LEGO</figcaption>
        </figure>
      </div>

      {projects.map((p) => <ProjectRow project={p} />)}
    </div>
  </section>
</Base>

<style>
  .photos { margin-bottom: 36px; align-items: stretch; }
  .photos figure { display: flex; flex-direction: column; }
  .photos img, .photos video { border-radius: 14px; box-shadow: var(--shadow); width: 100%; height: 100%; object-fit: cover; flex: 1; }
  .photos figcaption { margin-top: 8px; font-size: 0.8rem; color: var(--muted); text-align: center; }
</style>
